rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Test connection path
    match /test/connection {
      allow read: if true;
    }

    // Admin configuration
    match /settings/config {
      allow read: if true;
      allow write: if true;
    }

    // Portfolio content
    match /data/portfolio {
      allow read: if true;
      allow write: if true;
    }
  }
}
